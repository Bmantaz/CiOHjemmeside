@page "/sales"
@layout Layout.InternalLayout
@rendermode InteractiveServer

@inject ISalesService SalesService
@inject NavigationManager NavManager
@inject ProtectedSessionStorage SessionStorage
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.Security.Claims

<link rel="stylesheet" href="Components/Pages/Sales.razor.css" />

<PageTitle>Sales Dashboard</PageTitle>

<div class="pos-container">
    <div class="product-grid">
        @if (productGroups == null)
        {
            <div class="loading-state">
                <p>Indlæser produkter fra databasen...</p>
            </div>
        }
        else if (!productGroups.Any())
        {
            <div class="alert alert-warning">
                <h5>Ingen produkter fundet!</h5>
                <p>Databasen er tom. Kør Database Seeder for at oprette 'Basic-T' og 'Patches'.</p>
            </div>
        }
        else
        {
            @foreach (var group in productGroups)
            {
                <div class="product-card" @onclick="() => SelectProductGroup(group)">
                    <img src="@(string.IsNullOrEmpty(group.ImageUrl) ? "/images/placeholder.png" : group.ImageUrl)" alt="@group.GroupName" />
                    <div class="product-name">@group.GroupName</div>
                </div>
            }
        }
    </div>

    <div class="cart-section">
        <h3>Indkøbskurv</h3>
        <p class="seller-indicator">Aktiv sælger: <strong>@selectedRecipientName</strong></p>

        @if (!cart.Any())
        {
            <div class="cart-empty">Kurven er tom</div>
        }
        else
        {
            <div class="cart-items">
                @foreach (var item in cart)
                {
                    <div class="cart-item">
                        <span>@item.Variant.VariantName @item.Group.GroupName</span>
                        <span class="cart-item-price">@item.Variant.Price?.ToString("N2") kr.</span>
                        <button class="btn-remove-item" @onclick="() => RemoveFromCart(item)">×</button>
                    </div>
                }
            </div>
            <hr class="cart-divider" />
            <div class="cart-total">
                <span>Total</span>
                <span>@GetCartTotal().ToString("N2") kr.</span>
            </div>
        }

        <button class="btn-sell" @onclick="ShowPaymentModal" disabled="@(!cart.Any() || string.IsNullOrWhiteSpace(selectedRecipientName))">
            [ SÆLG ]
        </button>

        @if (!string.IsNullOrEmpty(saleStatusMessage))
        {
            <p class="text-success mt-3 mb-0">@saleStatusMessage</p>
        }
        @if (!string.IsNullOrEmpty(saleErrorMessage))
        {
            <p class="text-danger mt-3 mb-0">@saleErrorMessage</p>
        }
    </div>
</div>

@if (isSellerSelectionVisible)
{
    <div class="modal-backdrop"></div>
    <div class="modal-content seller-modal">
        <div class="modal-header"><h3>Åbn Shop</h3></div>
        <div class="modal-body text-center">
            <p>Hvem er aktiv sælger i denne session?</p>
            <div class="seller-grid">
                @foreach (var recipient in mobilePayRecipients)
                {
                    <button class="btn-seller-select" @onclick="() => SelectSellerAndOpenShop(recipient.Name)">@recipient.Name</button>
                }
            </div>
        </div>
    </div>
}

@if (selectedGroup != null)
{
    <div class="modal-backdrop" @onclick="CloseVariantModal"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h3>Vælg Varianter: @selectedGroup.GroupName</h3>
            <button class="btn-close-modal" @onclick="CloseVariantModal">×</button>
        </div>
        <div class="modal-body variant-grid">
            @foreach (var variant in selectedGroup.Variants)
            {
                <button class="btn-variant @(variant.StockQuantity <= 0 ? "disabled" : "")"
                        @onclick="() => AddToCart(selectedGroup, variant)"
                        disabled="@(variant.StockQuantity <= 0)">
                    <span class="variant-name">@variant.VariantName</span>
                    <span class="variant-stock">Lager: @variant.StockQuantity</span>
                </button>
            }
        </div>
    </div>
}

@if (isPaymentModalVisible)
{
    <div class="modal-backdrop" @onclick="ClosePaymentModal"></div>
    <div class="modal-content payment-modal">
        <div class="modal-header">
            <h3>Betaling</h3>
            <button class="btn-close-modal" @onclick="ClosePaymentModal">×</button>
        </div>
        <div class="modal-body text-center">
            <h4>Total: @GetCartTotal().ToString("N2") kr.</h4>
            <div class="payment-methods">
                <button class="btn-payment-method @(selectedPaymentMethod == "MobilePay" ? "active" : "")" @onclick="SetMobilePay">MobilePay</button>
                <button class="btn-payment-method @(selectedPaymentMethod == "Cash" ? "active" : "")" @onclick="SetCash">Cash</button>
            </div>

            @if (selectedPaymentMethod == "MobilePay")
            {
                <p>Send MobilePay til:</p>
                <p class="mobilepay-recipient">@GetSelectedRecipientDisplay()</p>
            }
            else
            {
                <div class="cash-box">
                    <label for="cashReceived">Cash modtaget (kr.)</label>
                    <input id="cashReceived" class="cash-input" type="number" min="0" step="1" @bind="cashReceivedInput" @bind:event="oninput" />
                    <p>Byttepenge: <strong>@GetCashChange().ToString("N2") kr.</strong></p>
                    @if (!IsCashPaymentValid())
                    {
                        <p class="text-danger small">Beløbet er mindre end totalen.</p>
                    }
                </div>
            }

            <button class="btn-complete-sale" @onclick="CompleteSale" disabled="@(isCompletingSale || !CanCompletePayment())">
                @if (isCompletingSale)
                {
                    <span>Behandler...</span>
                }
                else
                {

                    <span>BETALING GENNEMFØRT (OPDATER LAGER)</span>
                }
            </button>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<ProductGroup> productGroups = null;
    private List<(ProductGroup Group, ProductVariant Variant)> cart = new();
    private ProductGroup? selectedGroup;
    private bool isPaymentModalVisible = false;
    private bool isCompletingSale = false;
    private int _currentUserId;
    private string saleStatusMessage = string.Empty;
    private string saleErrorMessage = string.Empty;
    private string selectedRecipientName = string.Empty;
    private bool isSellerSelectionVisible = false;
    private string selectedPaymentMethod = "MobilePay";
    private string cashReceivedInput = string.Empty;

    private readonly List<MobilePayRecipient> mobilePayRecipients = new()
    {
        new("Sebastian", "42 23 80 30"),
        new("Henrik", "53 68 86 76"),
        new("Kristofer", "21 66 48 20"),
        new("Michal", "61 65 91 25"),
        new("Bjarke", "27 52 90 51")
    };
     
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var userIdClaim = user.FindFirstValue(ClaimTypes.NameIdentifier);
        _currentUserId = int.TryParse(userIdClaim, out var parsedUserId) ? parsedUserId : 0;

        await LoadSellerSelectionAsync();
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        try { productGroups = await SalesService.GetAllProductGroupsWithVariantsAsync(); }
        catch (Exception ex) { saleErrorMessage = $"Fejl ved indlæsning: {ex.Message}"; productGroups = new(); }
    }

    private async Task LoadSellerSelectionAsync()
    {
        try
        {
            var res = await SessionStorage.GetAsync<string>("CiO-ActiveSeller");
            if (res.Success && !string.IsNullOrWhiteSpace(res.Value)) { selectedRecipientName = res.Value; isSellerSelectionVisible = false; }
            else { isSellerSelectionVisible = true; }
        }
        catch { isSellerSelectionVisible = true; }
    }

    private async Task SelectSellerAndOpenShop(string name)
    {
        selectedRecipientName = name;
        isSellerSelectionVisible = false;
        await SessionStorage.SetAsync("CiO-ActiveSeller", name);
    }

    private void SelectProductGroup(ProductGroup group) => selectedGroup = group;
    private void CloseVariantModal() => selectedGroup = null;

    private void AddToCart(ProductGroup group, ProductVariant variant)
    {
        if (variant.StockQuantity > 0)
        {
            variant.StockQuantity--;
            cart.Add((group, variant));
            saleStatusMessage = string.Empty;
        }
    }

    private void RemoveFromCart((ProductGroup Group, ProductVariant Variant) item)
    {
        item.Variant.StockQuantity++;
        cart.Remove(item);
    }

    private void ShowPaymentModal()
    {
        saleStatusMessage = string.Empty;
        saleErrorMessage = string.Empty;
        isPaymentModalVisible = true;
    }

    private void ClosePaymentModal() => isPaymentModalVisible = false;

    private async Task CompleteSale()
    {
        if (!cart.Any() || _currentUserId <= 0 || isCompletingSale) return;

        isCompletingSale = true;
        saleErrorMessage = string.Empty;

        try
        {
            var saleItems = cart
                .GroupBy(item => new { item.Group.GroupName, item.Variant.VariantName, Price = item.Variant.Price ?? 0 })
                .Select(g => new SaleItemInput
                {
                    ProductGroupName = g.Key.GroupName,
                    VariantName = g.Key.VariantName,
                    Quantity = g.Count(),
                    UnitPrice = g.Key.Price
                })
                .ToList();

            await SalesService.RecordSaleAsync(_currentUserId, saleItems);

            saleStatusMessage = "Salg gennemført!";
            cart.Clear();
            isPaymentModalVisible = false;
            await LoadProductsAsync(); // Opdater lageret i UI fra DB
        }
        catch (Exception ex)
        {
            saleErrorMessage = $"Fejl ved lagring: {ex.Message}";
        }
        finally
        {
            isCompletingSale = false;
        }
    }

    private void SetMobilePay() => selectedPaymentMethod = "MobilePay";
    private void SetCash() => selectedPaymentMethod = "Cash";
    private decimal GetCartTotal() => cart.Sum(i => i.Variant.Price ?? 0m);

    private bool IsCashPaymentValid()
    {
        if (selectedPaymentMethod != "Cash") return true;
        return decimal.TryParse(cashReceivedInput, out var received) && received >= GetCartTotal();
    }

    private decimal GetCashChange()
    {
        if (!decimal.TryParse(cashReceivedInput, out var received)) return 0m;
        var change = received - GetCartTotal();
        return change < 0 ? 0m : change;
    }

    private bool CanCompletePayment() => !string.IsNullOrWhiteSpace(selectedRecipientName) && (selectedPaymentMethod == "MobilePay" || IsCashPaymentValid());

    private string GetSelectedRecipientDisplay()
    {
        var recipient = mobilePayRecipients.FirstOrDefault(r => r.Name == selectedRecipientName);
        return recipient != null ? $"{recipient.Name}: {recipient.PhoneNumber}" : "Vælg person";
    }

    private sealed record MobilePayRecipient(string Name, string PhoneNumber);
}