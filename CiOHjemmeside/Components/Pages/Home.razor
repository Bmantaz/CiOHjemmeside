@page "/"
@attribute [AllowAnonymous]
@inject IConcertService ConcertService

<link rel="stylesheet" href="Components/Pages/Home.razor.css" />

<PageTitle>Cursed Into Oblivion</PageTitle>

<div class="home-page">
    <section class="hero">
        <img src="/images/HEADER.png" alt="Cursed Into Oblivion" class="hero-logo" />
    </section>

    <section id="shows" class="content-section">
        <h2>Upcoming shows</h2>

        @if (isLoadingConcerts)
        {
            <p class="muted">Loading shows...</p>
        }
        else if (!upcomingConcerts.Any())
        {
            <p class="muted">No upcoming shows found yet.</p>
        }
        else
        {
            <ul class="concert-list">
                @foreach (var concert in upcomingConcerts)
                {
                    <li class="concert-item">
                        <span class="concert-date">@concert.EventDate.ToString("dd. MMM yyyy").ToUpper()</span>
                        <span class="concert-venue">@concert.VenueName</span>
                        <span class="concert-location">@concert.City, @concert.Country</span>

                        @if (!string.IsNullOrWhiteSpace(concert.OtherBands))
                        {
                            <span class="concert-location">With: @concert.OtherBands</span>
                        }

                        @if (concert.IsSoldOut)
                        {
                            <span class="concert-sold-out">[SOLD OUT]</span>
                        }
                        else if (!string.IsNullOrWhiteSpace(concert.TicketLink))
                        {
                            <a href="@concert.TicketLink" target="_blank" rel="noopener noreferrer" class="concert-ticket-link">[TICKETS]</a>
                        }
                        else
                        {
                            <span class="concert-soon">[SOON]</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(concert.FacebookEventLink))
                        {
                            <a href="@concert.FacebookEventLink" target="_blank" rel="noopener noreferrer" class="concert-ticket-link">[FACEBOOK]</a>
                        }
                    </li>
                }
            </ul>
        }

    </section>

    <section id="music" class="content-section release-section">
        <div>
            <h2>Listen to us on Spotify</h2>
            <p>Stream the album on major platforms and follow the latest drops.</p>
        </div>
        <iframe class="spotify-iframe"
                src="https://open.spotify.com/embed/artist/0UHWo7NpNBWTomTYIBS340?utm_source=generator&theme=0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"></iframe>
    </section>

    <section id="videos" class="content-section">
        <h2>Videos</h2>
        <div class="video-thumbnail-grid">
            @foreach (var video in featuredVideos)
            {
                <a class="video-card" href="@video.Url" target="_blank" rel="noopener noreferrer">
                    <img src="@GetVideoThumbnailOrFallback(video.Url, video.FallbackImageUrl)" alt="@video.Title" />
                </a>
            }
        </div>
    </section>

    <section id="bio" class="content-section">
        <h2>Introduction: A Void in the Danish Metal Scene</h2>
        <p>
            Denmark boasts a proud metal tradition, yet the scene has lacked the atmospheric heaviness that defines
            the international modern metal sound. That changes now. Cursed Into Oblivion has emerged from Vejle with
            a clear mission: to introduce Denmark to a soundscape and an expression the nation has been needing.
        </p>
        <h2>The Sound: Innovation Meets Brutality</h2>
        <p>
            The band operates in a boundless territory between modern deathcore and metalcore, known for its heavy,
            dissonant atmosphere and complex rhythmics. But Cursed Into Oblivion does not stop there.
        </p>
        <p>
            By integrating elements of electronic music and theatrical devices, the band creates its own unique sonic
            landscape. Cursed Into Oblivion is not here to participate, but to set a new standard for what Danish metal
            can hold in terms of technical prowess and originality.
        </p>
        <p>
            The debut album <strong>LIFE</strong> is a self-produced release built around hard riffs, dynamic vocals and
            a live-focused sound made for clubs and festival stages.
        </p>
        <p>
            Every track is engineered to hit hard live while keeping atmosphere and melody in the center.
        </p>
    </section>

    <section id="gallery" class="content-section image-section">
        <img src="/images/Updated%20Band%20Picuture%20FULL.jpg" alt="Cursed Into Oblivion full band" class="full-band-image" />
        <div class="band-bio-grid">
            <div class="member-bio"><strong>Henrik Mørch</strong><span>Drums</span></div>
            <div class="member-bio"><strong>Sebastian Viuf</strong><span>Guitar</span></div>
            <div class="member-bio"><strong>Michal Andersen</strong><span>Vocals</span></div>
            <div class="member-bio"><strong>Kristofer Ingi</strong><span>Guitar</span></div>
            <div class="member-bio"><strong>Bjarke Pallisgaard</strong><span>Bass, Backing vocals</span></div>
        </div>
    </section>

    <section id="contact" class="content-section">
        <h2>Contact</h2>
        <p>Booking & General inquiries: Cursedintooblivion00@gmail.com</p>
    </section>
</div>

@code {
    private List<Concert> upcomingConcerts = new();
    private bool isLoadingConcerts = true;
    private readonly List<FeaturedVideo> featuredVideos = new()
    {
        new FeaturedVideo("Video 1", "https://www.youtube.com/watch?v=OnJBkPtUCdY", "/images/Updated%20Band%20Picuture%20FULL.jpg"),
        new FeaturedVideo("Video 2", "https://www.youtube.com/watch?v=Ej8VHy-4O6I", "/images/HEADER.png"),
        new FeaturedVideo("Video 3", "https://www.youtube.com/watch?v=_1F33fHpVOE", "/images/SPEAR%20LOGO.png")
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            upcomingConcerts = (await ConcertService.GetUpcomingConcertsAsync()).ToList();
        }
        catch
        {
            upcomingConcerts = new List<Concert>();
        }
        finally
        {
            isLoadingConcerts = false;
        }
    }

    private static string GetVideoThumbnailOrFallback(string videoUrl, string fallbackImageUrl)
    {
        var videoId = TryExtractYouTubeVideoId(videoUrl);
        return string.IsNullOrWhiteSpace(videoId)
            ? fallbackImageUrl
            : $"https://i.ytimg.com/vi/{videoId}/hqdefault.jpg";
    }

    private static string? TryExtractYouTubeVideoId(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            if (uri.Host.Contains("youtu.be", StringComparison.OrdinalIgnoreCase))
            {
                return uri.AbsolutePath.Trim('/');
            }

            if (uri.Host.Contains("youtube.com", StringComparison.OrdinalIgnoreCase))
            {
                var query = uri.Query;
                if (!string.IsNullOrWhiteSpace(query))
                {
                    var parts = query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
                    foreach (var part in parts)
                    {
                        var kv = part.Split('=', 2);
                        if (kv.Length == 2 && kv[0] == "v")
                        {
                            return kv[1];
                        }
                    }
                }
            }
        }

        return null;
    }

    private sealed record FeaturedVideo(string Title, string Url, string FallbackImageUrl);
}
