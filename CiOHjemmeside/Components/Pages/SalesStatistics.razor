@page "/sales-statistics"
@layout Layout.InternalLayout
@rendermode InteractiveServer

@inject ISalesService SalesService
@inject NavigationManager NavManager

<PageTitle>Salg Statistik</PageTitle>

<h1>Salg Statistik</h1>

<div class="d-flex gap-2 align-items-end mb-3">
    <div>
        <label class="form-label">Dato</label>
        <InputDate class="form-control" @bind-Value="selectedDate" />
    </div>
    <button class="btn btn-primary" @onclick="LoadStatistics" disabled="@isLoading">
        @(isLoading ? "Indlæser..." : "Hent statistik")
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else if (statistics != null)
{
    <h4>Dato: @statistics.Date.ToString("dd-MM-yyyy")</h4>

    @if (!statistics.Rows.Any())
    {
        <p>Ingen salg registreret for denne dato.</p>
    }
    else
    {
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Produkt</th>
                    <th>Størrelse/Variant</th>
                    <th>Antal solgt</th>
                    <th>Omsætning</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in statistics.Rows)
                {
                    <tr>
                        <td>@row.ProductGroupName</td>
                        <td>@row.VariantName</td>
                        <td>@row.TotalSold</td>
                        <td>@row.Revenue.ToString("N2") kr.</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <p class="mb-1"><strong>Total antal solgt:</strong> @statistics.TotalItemsSold</p>
        <p class="mb-0"><strong>Total omsætning:</strong> @statistics.TotalRevenue.ToString("N2") kr.</p>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private DateTime selectedDate = DateTime.Today;
    private SalesStatisticsResult? statistics;
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!user.IsInRole("Admin"))
        {
            var target = user.IsInRole("Sales") ? "/sales" : "/dashboard";
            NavManager.NavigateTo(target, forceLoad: true);
            return;
        }

        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            statistics = await SalesService.GetStatisticsForDateAsync(selectedDate);
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunne ikke hente statistik: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
