@page "/reset-password/{UserId:int}"
@layout Layout.EmptyLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]

@inject IUserService UserService
@inject NavigationManager NavManager

<PageTitle>Reset Password</PageTitle>

<div class="login-container">
    <div class="login-box">
        <h1>Reset Password</h1>

        <div class="form-group">
            <label for="newPassword">New Password</label>
            <input id="newPassword" type="password" class="form-control" @bind="newPassword" />
        </div>

        <div class="form-group">
            <label for="confirmPassword">Confirm Password</label>
            <input id="confirmPassword" type="password" class="form-control" @bind="confirmPassword" />
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="login-error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="login-success">@successMessage</div>
        }

        <button class="btn btn-login" @onclick="HandleReset" disabled="@isProcessing">
            @(isProcessing ? "Saving..." : "Set Password")
        </button>
    </div>
</div>

@code {
    [Parameter]
    public int UserId { get; set; }

    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isProcessing;

    private async Task HandleReset()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "Password is required.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (!IsValidPassword(newPassword))
        {
            errorMessage = "Password must be at least 8 characters, include one uppercase letter, one number, and one special character.";
            return;
        }

        isProcessing = true;
        try
        {
            var user = await UserService.GetByIdAsync(UserId);
            if (user == null)
            {
                errorMessage = "User not found.";
                return;
            }

            user.PasswordHash = BCrypt.Net.BCrypt.HashPassword(newPassword);
            user.MustResetPassword = false;
            await UserService.UpdateAsync(user);

            successMessage = "Password updated. You can now log in.";
            await Task.Delay(800);
            NavManager.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to reset password: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private static bool IsValidPassword(string password)
    {
        if (password.Length < 8) return false;
        bool hasUpper = password.Any(char.IsUpper);
        bool hasNumber = password.Any(char.IsDigit);
        bool hasSpecial = password.Any(ch => !char.IsLetterOrDigit(ch));
        return hasUpper && hasNumber && hasSpecial;
    }
}
