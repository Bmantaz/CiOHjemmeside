@page "/cookie-policy"
@layout Layout.MainLayout
@rendermode InteractiveServer

<PageTitle>Cookie Policy</PageTitle>

<div class="epk-wrapper">
    <h1>Cookie Policy</h1>

    <p>This site uses a minimal set of cookies necessary for the website to function, including session and authentication cookies.</p>

    <h2>What cookies do we use?</h2>
    <ul>
        <li><strong>Essential cookies</strong>: Required for login, session state and the site to function. These are always enabled.</li>
        <li><strong>Optional analytics cookies</strong>: We may use anonymous analytics to understand site usage. These are only enabled if you click "Accept" on the cookie banner.</li>
    </ul>

    <h2>Your choices</h2>
    <p>You can accept or reject optional cookies using the cookie banner. To withdraw consent, clear your browser storage for this site or use your browser's privacy controls.</p>

    <h2>More information</h2>
    <p>If you have questions about privacy or cookies, contact: <a href="mailto:Cursedintooblivion00@gmail.com">Cursedintooblivion00@gmail.com</a></p>
</div>
