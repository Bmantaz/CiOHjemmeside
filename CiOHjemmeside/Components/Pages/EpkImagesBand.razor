@page "/epk-cio-access-2026/images/band"
@layout Layout.MainLayout
@rendermode InteractiveServer

<link rel="stylesheet" href="Components/Pages/Epk.razor.css" />

<PageTitle>EPK - Band Pictures</PageTitle>

<div class="epk-wrapper">
    <h1>Band Picture</h1>

    <section class="epk-section">
        <h2>Files</h2>

        <div class="epk-image-item">
            <img class="epk-mini-thumb" src="/EPK/Updated%20Band%20Picuture%20FULL.jpg" alt="Band picture" width="110" height="110" style="width:110px;height:110px;" />
            <span>Updated Band Picuture FULL.jpg</span>
            <div class="epk-actions">
                <a class="epk-link-button" href="/EPK/Updated%20Band%20Picuture%20FULL.jpg" target="_blank" rel="noopener noreferrer">Open</a>
                <a class="epk-link-button" href="/EPK/Updated%20Band%20Picuture%20FULL.jpg" download>Download</a>
            </div>
        </div>

        <div class="epk-image-item">
            <img class="epk-mini-thumb" src="/EPK/Updated%20Band%20Picuture%20FULL%20WITH%20LOGO.jpg" alt="Band picture with logo" width="110" height="110" style="width:110px;height:110px;" />
            <span>Updated Band Picuture FULL WITH LOGO.jpg</span>
            <div class="epk-actions">
                <a class="epk-link-button" href="/EPK/Updated%20Band%20Picuture%20FULL%20WITH%20LOGO.jpg" target="_blank" rel="noopener noreferrer">Open</a>
                <a class="epk-link-button" href="/EPK/Updated%20Band%20Picuture%20FULL%20WITH%20LOGO.jpg" download>Download</a>
            </div>
        </div>
    </section>

    <a class="epk-link" href="/epk-cio-access-2026/images">← Back to Images</a>
</div>
