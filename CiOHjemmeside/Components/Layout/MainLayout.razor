@inherits LayoutComponentBase

<div class="page">
    <main>
        <div class="top-row px-4">
            <div class="top-nav left-nav">
                <a href="/#shows">Shows</a>
                <a href="/#music">Music</a>
                <a href="/#videos">Videos</a>
                <a href="/#bio">Bio</a>
                <a href="/#gallery">Gallery</a>
                <a href="/#contact">Contact</a>
            </div>

            <a href="/" class="top-brand" aria-label="Cursed Into Oblivion Home">
                <img src="/images/HEADER.png" alt="Cursed Into Oblivion" />
            </a>

            <div class="top-nav right-nav">
                <a href="https://open.spotify.com/artist/0UHWo7NpNBWTomTYIBS340" target="_blank" rel="noopener noreferrer">Spotify</a>
                <a href="https://www.facebook.com/CursedIntoOblivion" target="_blank" rel="noopener noreferrer">Facebook</a>
                <a href="https://www.instagram.com/cursed_into_oblivion/" target="_blank" rel="noopener noreferrer">Instagram</a>
                <a href="https://www.tiktok.com/@@cursedintooblivion" target="_blank" rel="noopener noreferrer">TikTok</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="main-footer">
            © @DateTime.Now.Year Cursed Into Oblivion
            <span class="px-2">|</span>
            <a href="login" class="login-link">member login</a>
        </footer>
    </main>
