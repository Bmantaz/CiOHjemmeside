@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager NavManager

<AuthorizeView>
    <Authorized>
        <div class="internal-page">
            <nav class="internal-nav">
                <div class="nav-brand">
                    CIO Dashboard
                </div>
                <div class="nav-links">
                    <NavLink class="nav-link" href="/">Frontpage</NavLink>

                    <AuthorizeView Roles="Admin,Member" Context="calendarContext">
                        <Authorized>
                            <NavLink class="nav-link" href="dashboard">Kalender</NavLink>
                            <NavLink class="nav-link" href="epk-cio-access-2026">EPK</NavLink>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Roles="Admin,Sales" Context="salesContext">
                        <Authorized>
                            <NavLink class="nav-link" href="sales">Sales</NavLink>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Roles="Admin" Context="adminContext">
                        <Authorized>
                            <NavLink class="nav-link" href="users">Brugerstyring</NavLink>
                            <NavLink class="nav-link" href="sales-statistics">Salg Statistik</NavLink>
                            <NavLink class="nav-link" href="shows-admin">Shows Admin</NavLink>
                        </Authorized>
                    </AuthorizeView>

                    <button class="nav-link logout-button" @onclick="HandleLogout">Log Ud</button>
                </div>
            </nav>

            <main class="internal-content">
                @Body
            </main>
        </div>
    </Authorized>

    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        var authProvider = (CustomAuthStateProvider)AuthProvider;
        await authProvider.LogoutAsync();

        NavManager.NavigateTo("/login", forceLoad: true);
    }
}